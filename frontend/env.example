# Copy this to .env.local for local overrides, or set VITE_API_BASE as a
# build-time environment variable in your Vercel/Netlify project settings.

# Local dev (default if unset):
# VITE_API_BASE=http://localhost:8000

# Production — point this at your deployed Render/Railway backend URL:
VITE_API_BASE=https://your-backend-app.onrender.com
